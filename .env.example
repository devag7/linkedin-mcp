# LinkedIn Pro MCP — Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# AUTHENTICATION (at least one method required)
# ============================================================

# Method 1: LinkedIn OAuth 2.0 Access Token (recommended)
# Obtain from LinkedIn Developer Portal
# LINKEDIN_ACCESS_TOKEN=

# Method 2: LinkedIn Session Cookie (quick setup)
# Copy the 'li_at' cookie value from your browser
# LINKEDIN_COOKIE=

# CSRF token — copy the 'JSESSIONID' cookie value (include quotes)
# LINKEDIN_CSRF_TOKEN=

# ============================================================
# SERVER CONFIGURATION
# ============================================================

# Port for HTTP transport (default: 3000)
PORT=3000

# Transport mode: stdio | http (default: stdio)
TRANSPORT=stdio

# Logging level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# ============================================================
# PERFORMANCE TUNING
# ============================================================

# Cache TTL in seconds for read operations (default: 300)
CACHE_TTL=300

# Rate limit: max requests per minute (default: 30)
RATE_LIMIT_RPM=30

# Request timeout in milliseconds (default: 30000)
REQUEST_TIMEOUT=30000
